{
  "mcpServers": {
    "blender_mcp": {
      "command": "cmd",
      "args": [
        "/c",
        "uvx",
        "blender-mcp"
      ],
      "env": {
        "BLENDER_HOST": "localhost",
        "BLENDER_PORT": "9876"
      },
      "disabled": false,
      "autoApprove": [
        "get_scene_info",
        "execute_blender_code"
      ]
    }
  },
  "powers": {
    "mcpServers": {
      "power-supabase-hosted-supabase": {
        "url": "https://mcp.supabase.com/mcp",
        "disabled": false
      }
    }
  }
}